# ============================================
# EchoLearn - Environment Variables
# ============================================
# Copy this file to .env and fill in values
# ============================================

# Backend
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/echolearn
JWT_SECRET=your-jwt-secret-key-change-this
PORT=5000

# Frontend (prefix with REACT_APP_)
REACT_APP_API_URL=https://your-vercel-app.vercel.app/api
