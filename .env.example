# ============================================
# EchoLearn - Environment Variables
# ============================================
# Copy this file to .env and fill in values
# ============================================

# Backend
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/echolearn?retryWrites=true&w=majority
JWT_SECRET=your-jwt-secret-key-change-this
OPENAI_API_KEY=sk-your-openai-key-here
PORT=5000

# Frontend (prefix with REACT_APP_)
REACT_APP_API_URL=https://your-vercel-app.vercel.app/api
